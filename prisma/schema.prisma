generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Language {
  ar
  en
}

enum TicketStatus {
  open
  closed
}

model GuildConfig {
  guildId               String   @id
  language              Language @default(ar)
  timezone              String   @default("Asia/Riyadh")
  primaryColor          String   @default("#D4AF37")
  secondaryColor        String   @default("#C0C0C0")
  notificationsEnabled  Boolean  @default(true)
  maintenanceMode       Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  schedules             Schedule[]
  autoResponses         AutoResponse[]
  tickets               Ticket[]
}

model Schedule {
  id          String   @id @default(cuid())
  guildId     String
  name        String
  cron        String
  channelId   String
  actionType  String
  payloadAr   String
  payloadEn   String
  enabled     Boolean  @default(true)
  timezone    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  guild       GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@index([guildId])
}

model AutoResponse {
  id          String   @id @default(cuid())
  guildId     String
  keyword     String
  responseAr  String
  responseEn  String
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  guild       GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@index([guildId])
}

model Ticket {
  id          String       @id @default(cuid())
  guildId     String
  channelId   String
  creatorId   String
  assigneeId  String?
  status      TicketStatus @default(open)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  guild       GuildConfig  @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@index([guildId])
}

model Developer {
  userId      String   @id
  addedAt     DateTime @default(now())
}

model ErrorEntry {
  id          String   @id @default(cuid())
  scope       String
  message     String
  metadata    Json?
  createdAt   DateTime @default(now())
}
